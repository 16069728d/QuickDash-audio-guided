<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QuickDASH Audio Assessment</title>
    <style>
        :root {
            --bg: #f0f2f5;
            --card: #ffffff;
            --primary: #4a90e2;
            --option1: #2ecc71; /* Green */
            --option2: #8bc34a;
            --option3: #f1c40f; /* Yellow */
            --option4: #e67e22; /* Orange */
            --option5: #e74c3c; /* Red */
        }

        body {
            font-family: system-ui, -apple-system, sans-serif;
            background-color: var(--bg);
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            color: #333;
        }

        #quiz-container {
            width: 95%;
            max-width: 600px;
            background: var(--card);
            padding: 30px;
            border-radius: 24px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            text-align: center;
        }

        .progress-container {
            width: 100%;
            height: 8px;
            background: #eee;
            border-radius: 4px;
            margin-bottom: 30px;
            overflow: hidden;
        }

        #progress-bar {
            height: 100%;
            background: var(--primary);
            width: 0%;
            transition: width 0.4s ease;
        }

        h1 { font-size: 1.5rem; margin-bottom: 10px; }
        .question-text { font-size: 1.8rem; font-weight: bold; margin: 20px 0; line-height: 1.3; }

        .btn-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 15px;
            margin-top: 30px;
        }

        .option-btn {
            border: none;
            padding: 25px;
            border-radius: 16px;
            font-size: 1.4rem;
            font-weight: bold;
            color: white;
            cursor: pointer;
            transition: transform 0.1s, filter 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .option-btn:active { transform: scale(0.96); }
        .option-btn:hover { filter: brightness(90%); }

        .opt-1 { background-color: var(--option1); }
        .opt-2 { background-color: var(--option2); }
        .opt-3 { background-color: var(--option3); color: #222; }
        .opt-4 { background-color: var(--option4); }
        .opt-5 { background-color: var(--option5); }

        .audio-replay {
            background: none;
            border: 2px solid var(--primary);
            color: var(--primary);
            padding: 10px 20px;
            border-radius: 30px;
            margin-top: 20px;
            font-weight: bold;
            cursor: pointer;
        }

        #start-screen, #result-screen { display: block; }
        #question-screen { display: none; }

        .hidden { display: none !important; }

        .score-display { font-size: 4rem; font-weight: 800; color: var(--primary); margin: 20px 0; }
    </style>
</head>
<body>

<div id="quiz-container">
    <div id="start-screen">
        <div style="font-size: 5rem; margin-bottom: 20px;">👋</div>
        <h1>QuickDASH Assessment</h1>
        <p>This page will read the questions to you.</p>
        <button class="option-btn opt-1" style="width:100%" onclick="startQuiz()">PRESS TO START</button>
    </div>

    <div id="question-screen">
        <div class="progress-container"><div id="progress-bar"></div></div>
        <div id="q-number" style="color: var(--primary); font-weight: bold;">Question 1 of 11</div>
        <div id="q-text" class="question-text">Loading...</div>
        
        <div class="btn-grid">
            <button class="option-btn opt-1" onclick="handleAnswer(1)">1. No Difficulty</button>
            <button class="option-btn opt-2" onclick="handleAnswer(2)">2. Mild Difficulty</button>
            <button class="option-btn opt-3" onclick="handleAnswer(3)">3. Moderate Difficulty</button>
            <button class="option-btn opt-4" onclick="handleAnswer(4)">4. Severe Difficulty</button>
            <button class="option-btn opt-5" onclick="handleAnswer(5)">5. Unable</button>
        </div>

        <button class="audio-replay" onclick="speakCurrentQuestion()">🔊 Hear Again</button>
    </div>

    <div id="result-screen" class="hidden">
        <h1>Your Score</h1>
        <div id="final-score" class="score-display">0.0</div>
        <p>0 is no disability. 100 is complete disability.</p>
        <button class="option-btn opt-1" style="width:100%" onclick="location.reload()">RESTART</button>
    </div>
</div>

<script>
    const questions = [
        "Open a tight or new jar.",
        "Do heavy household chores, like washing walls or floors.",
        "Carry a shopping bag or briefcase.",
        "Wash your back.",
        "Use a knife to cut food.",
        "Recreational activities in which you take some force or impact through your arm, shoulder or hand.",
        "To what extent has your arm, shoulder or hand problem interfered with your normal social activities?",
        "Were you limited in your work or other regular daily activities?",
        "Arm, shoulder or hand pain.",
        "Tingling, or pins and needles, in your arm, shoulder or hand.",
        "How much difficulty have you had sleeping because of pain?"
    ];

    let currentIdx = 0;
    let scores = [];

    function speak(text) {
        window.speechSynthesis.cancel();
        const msg = new SpeechSynthesisUtterance(text);
        msg.rate = 0.85; // Slightly slower for better understanding
        msg.pitch = 1;
        window.speechSynthesis.speak(msg);
    }

    function startQuiz() {
        document.getElementById('start-screen').classList.add('hidden');
        document.getElementById('question-screen').style.display = 'block';
        loadQuestion();
    }

    function loadQuestion() {
        const q = questions[currentIdx];
        document.getElementById('q-number').innerText = `Question ${currentIdx + 1} of 11`;
        document.getElementById('q-text').innerText = q;
        document.getElementById('progress-bar').style.width = ((currentIdx + 1) / 11 * 100) + "%";
        
        speakCurrentQuestion();
    }

    function speakCurrentQuestion() {
        const q = questions[currentIdx];
        let instruction = "Rate your difficulty: ";
        
        // Custom prompts for different question types
        if (currentIdx === 6) instruction = "Regarding social activities: ";
        if (currentIdx >= 8) instruction = "Regarding your symptoms: ";

        speak(instruction + q + ". Choose 1 for no difficulty, to 5 for unable.");
    }

    function handleAnswer(val) {
        scores.push(val);
        currentIdx++;

        if (currentIdx < questions.length) {
            loadQuestion();
        } else {
            calculateResult();
        }
    }

    function calculateResult() {
        document.getElementById('question-screen').style.display = 'none';
        document.getElementById('result-screen').classList.remove('hidden');

        // QuickDASH Formula: [(Sum / n) - 1] * 25
        const sum = scores.reduce((a, b) => a + b, 0);
        const result = ((sum / 11) - 1) * 25;
        
        document.getElementById('final-score').innerText = result.toFixed(1);
        speak("Assessment complete. Your score is " + result.toFixed(1));
    }
</script>

</body>
</html>
